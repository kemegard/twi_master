#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = D:\work\ncs\toolchains\fd21892d0f\opt\bin\cmake.exe --regenerate-during-build -SD:\work\ncs\v3.2.0\twi_master -BD:\work\ncs\v3.2.0\twi_master\build\twi_master
  description = Re-running CMake...
  generator = 1


#############################################
